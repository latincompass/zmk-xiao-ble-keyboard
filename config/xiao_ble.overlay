/ {
    gpio-keys {
        compatible = "gpio-keys";
        key_0: key@0 { gpios = <&gpio0 2 GPIO_ACTIVE_LOW>; zmk,keycode = <ZMK_KEY_A>; };
        key_1: key@1 { gpios = <&gpio0 3 GPIO_ACTIVE_LOW>; zmk,keycode = <ZMK_KEY_B>; };
        key_2: key@2 { gpios = <&gpio0 4 GPIO_ACTIVE_LOW>; zmk,keycode = <ZMK_KEY_C>; };
    };
};

&bt { status = "okay"; };
&usb { status = "disabled"; };
